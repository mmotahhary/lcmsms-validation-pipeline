{
  "project": {
    "name": "LC-MS-MS Bioanalytical Pipeline",
    "author": "Majid Motahhary"
  },

  "paths": {
    "raw": "data/raw",
    "processed": "data/processed",
    "output": "data/output",
    "logs": "logs",
    "reports": "reports"
  },

  "assay": {
    "analyte": "25-OH Vitamin D3",
    "internal_standard": "d6-25-OH Vitamin D3",
    "matrix": "Human Plasma",
    "column": "C18 2.1 x 50 mm, 1.7 um",
    "ionization": "ESI Positive",
    "quantitation": "MRM",
    "retention_time_min": 3.25,
    "rt_drift_window": 0.15
  },

  "batch": {
    "id_prefix": "BATCH"
  },

  "simulation": {
    "random_seed": 42,
    "peak_area_noise_cv": 0.08,
    "is_fluctuation_cv": 0.05,
    "rt_drift_sd": 0.03,
    "outlier_probability": 0.03,
    "n_unknowns": 10
  },

  "calibration": {
    "levels_ngml": [
      5,
      10,
      20,
      40,
      60,
      80,
      100
    ],
    "lloq_ngml": 5,
    "uloq_ngml": 100,
    "model": "1/x2",
    "r2_threshold": 0.99,
    "min_levels_pass": 6
  },

  "qc": {
    "levels": {
      "LLOQ": 5,
      "LOW": 15,
      "MID": 50,
      "HIGH": 85
    },

    "replicates_per_level": 3,
    "min_qc_pass_per_level": 2,
    "min_qc_levels_pass": 3,

    "accuracy_pct": {
      "lloq": 20,
      "standard": 15
    },

    "precision_cv_pct": {
      "lloq": 20,
      "standard": 15
    }
  },

  "is_control": {
    "cv_warning_pct": 15,
    "cv_fail_pct": 20
  }
}